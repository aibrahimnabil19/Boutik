{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Boutik",
  "version": "0.2.0",
  "identifier": "com.zarafi.boutik",
  "build": {
    "beforeDevCommand": "pnpm --dir ../web dev",
    "beforeBuildCommand": "pnpm --dir ../web build:native",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../../web/out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Boutik",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "languages": [
          "French"
        ],
        "displayLanguageSelector": false
      },
      "wix": {
        "language": "fr-FR"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://boutik-app-one.vercel.app/api/desktop-update"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUxMURDOTg2NzFBNkNENTQKUldSVXphWnhoc2tkVWY5WHRyQjBvN2NubDJPMUZzaHJmaTZEemZFQ1lKK2htYTFJMjNnaFNpU0gK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}